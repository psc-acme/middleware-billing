{
    "name": "psc-acme/middleware-billing",
    "description": "Package middleware-billing for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\MiddlewareBilling\\": "src/"
        }
    },
    "require": {
        "php": ">=8.1",
        "nikic/php-parser": "^5.0",
        "illuminate/database": "^11.0",
        "league/csv": "^9.0",
        "symfony/http-kernel": "^6.2",
        "psc-acme/proxy-billing": "^1.0",
        "psc-acme/core-billing": "^1.0",
        "psc-acme/engine-billing": "^1.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}